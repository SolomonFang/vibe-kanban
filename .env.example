# Copy to .env and adjust as needed ( .env is gitignored ).

# --- Development (pnpm run dev) ---
# Fixed ports keep the browser origin stable (localStorage, cache, etc.).
FRONTEND_PORT=3003
BACKEND_PORT=3004

# Allow setup-dev-environment.js to pick new ports when the above are busy.
# DEV_PORTS_DYNAMIC=1

# --- Production / npx vibe-kanban ---
# Default in release binary is 7964 if unset. Do not use PORT=0 unless you want a random 5-digit port.
PORT=7964
HOST=127.0.0.1

# Must match the URL you open in the browser (dev: http://localhost:${FRONTEND_PORT}).
# VK_ALLOWED_ORIGINS=http://localhost:3003
